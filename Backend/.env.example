# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string
AZURE_STORAGE_CONTAINER_NAME=requirement-docs

# Azure Cosmos DB
COSMOS_DB_URL=your_cosmos_db_url
COSMOS_DB_KEY=your_cosmos_db_key
COSMOS_DB_NAME=ai-test-generator
COSMOS_PROJECTS_CONTAINER=projects
COSMOS_ARTIFACTS_CONTAINER=artifacts
COSMOS_SESSIONS_CONTAINER=sessions

# OpenAI / Azure OpenAI
OPENAI_API_KEY=your_openai_api_key
AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Jira (direct SDK fallback)
JIRA_SERVER=https://your-org.atlassian.net
JIRA_EMAIL=your_email@example.com
JIRA_API_TOKEN=your_jira_api_token

# ─── MCP Servers ────────────────────────────────────────────────────────────
# Jira MCP Server  (set JIRA_MCP_ENABLED=true once your MCP server is running)
JIRA_MCP_SERVER_URL=http://localhost:3100/sse
JIRA_MCP_ENABLED=false

# CosmosDB MCP Server
COSMOS_MCP_SERVER_URL=http://localhost:3101/sse
COSMOS_MCP_ENABLED=false

# App Settings
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000"]
